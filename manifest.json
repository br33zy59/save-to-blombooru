{
  "manifest_version": 2,
  "default_locale": "en",
  "name": "__MSG_extensionName__",
  "version": "2.0",
  "description": "__MSG_extensionDescription__",

  "permissions": [
    "contextMenus",
    "storage",
    "tabs",
    "<all_urls>",
    "notifications"
  ],

  "optional_permissions": [
    "http://*/",
    "https://*/"
  ],

  "background": {
    "scripts": ["servers.js", "auth.js", "media-context.js", "background.js"],
    "persistent": true
  },

  "browser_action": {
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png"
    },
    "default_title": "__MSG_browserActionTitle__"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false,
    "browser_style": true
  },

  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
