{
  "manifest_version": 2,
  "default_locale": "en",
  "name": "__MSG_extensionName__",
  "version": "1.1",
  "description": "__MSG_extensionDescription__",

  "browser_specific_settings": {
    "gecko": {
      "id": "save-to-blombooru@foo",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "contextMenus",
    "storage",
    "tabs",
    "scripting",
    "<all_urls>",
    "notifications"
  ],

  "optional_permissions": [
    "http://*/",
    "https://*/"
  ],

  "background": {
    "scripts": [
      "browser.js",
      "permissions.js",
      "tab-scripting.js",
      "servers.js",
      "auth.js",
      "media-context.js",
      "background.js"
    ],
    "persistent": true
  },

  "browser_action": {
    "default_icon": "icon.png",
    "default_title": "__MSG_browserActionTitle__",
    "default_popup": "popup.html"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false,
    "browser_style": true
  },

  "icons": {
    "128": "icon.png"
  }
}
