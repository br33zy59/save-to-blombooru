{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extensionName__",
  "version": "1.1",
  "description": "__MSG_extensionDescription__",

  "browser_specific_settings": {
    "gecko": {
      "id": "save-to-blombooru@foo",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "tabs",
    "notifications",
    "scripting"
  ],

  "optional_host_permissions": ["http://*/*", "https://*/*"],

  "background": {
    "scripts": [
      "browser.js",
      "permissions.js",
      "tab-scripting.js",
      "media-context.js",
      "servers.js",
      "auth.js",
      "background.js"
    ]
  },

  "action": {
    "default_icon": "icon.png",
    "default_title": "__MSG_browserActionTitle__",
    "default_popup": "popup.html"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },

  "icons": {
    "128": "icon.png"
  }
}
