{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extensionName__",
  "version": "1.2",
  "description": "__MSG_extensionDescription__",

  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "tabs",
    "windows",
    "notifications",
    "scripting"
  ],

  "optional_host_permissions": ["http://*/*", "https://*/*"],

  "action": {
    "default_icon": "icon.png",
    "default_title": "__MSG_browserActionTitle__",
    "default_popup": "popup.html"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },

  "icons": {
    "128": "icon.png"
  }
}
